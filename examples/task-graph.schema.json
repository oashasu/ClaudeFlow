{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClaudeFlow Task Graph",
  "type": "object",
  "required": ["tasks"],
  "properties": {
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["task_id", "prompt"],
        "properties": {
          "task_id": {
            "type": "string",
            "minLength": 1
          },
          "prompt": {
            "type": "string",
            "minLength": 1
          },
          "owner_role": {
            "type": "string"
          },
          "task_type": {
            "type": "string"
          },
          "priority": {
            "oneOf": [
              { "type": "string" },
              { "type": "integer" }
            ]
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" }
          },
          "read_paths": {
            "type": "array",
            "items": { "type": "string" }
          },
          "write_paths": {
            "type": "array",
            "items": { "type": "string" }
          },
          "shared_files": {
            "type": "array",
            "items": { "type": "string" }
          },
          "protocol_refs": {
            "type": "array",
            "items": { "type": "string" }
          },
          "design_refs": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
