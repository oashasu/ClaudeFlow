{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClaudeFlow Runtime Plan",
  "type": "object",
  "required": ["runnable", "blocked", "running"],
  "properties": {
    "runnable": {
      "type": "array",
      "items": { "$ref": "#/$defs/runnableTask" }
    },
    "blocked": {
      "type": "array",
      "items": { "$ref": "#/$defs/runtimeReasonItem" }
    },
    "running": {
      "type": "array",
      "items": { "$ref": "#/$defs/runtimeReasonItem" }
    }
  },
  "$defs": {
    "runnableTask": {
      "type": "object",
      "required": ["task_id", "priority", "owner_role", "task_type"],
      "properties": {
        "task_id": { "type": "string", "minLength": 1 },
        "priority": { "type": "string", "minLength": 1 },
        "owner_role": { "type": "string", "minLength": 1 },
        "task_type": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    },
    "runtimeReasonItem": {
      "type": "object",
      "required": ["task_id", "priority", "reason_code", "reason"],
      "properties": {
        "task_id": { "type": "string", "minLength": 1 },
        "priority": { "type": "string", "minLength": 1 },
        "reason_code": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
