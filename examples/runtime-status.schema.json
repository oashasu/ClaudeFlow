{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClaudeFlow Runtime Status",
  "type": "object",
  "required": [
    "repo_path",
    "active_agents",
    "queued_tasks",
    "completed_tasks",
    "failed_tasks",
    "intervention_required",
    "running_tasks"
  ],
  "properties": {
    "repo_path": { "type": "string", "minLength": 1 },
    "active_agents": { "type": "integer", "minimum": 0 },
    "queued_tasks": { "type": "integer", "minimum": 0 },
    "completed_tasks": { "type": "integer", "minimum": 0 },
    "failed_tasks": { "type": "integer", "minimum": 0 },
    "intervention_required": { "type": "boolean" },
    "running_tasks": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": true
}